{
  "display_information": {
    "name": "Lunchinator",
    "description": "Pick where to eat. Share the DoorDash group order. Done.",
    "background_color": "#00233A"
  },
  "features": {
    "bot_user": {
      "display_name": "Lunchinator",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/lunchinator",
        "description": "Pick a restaurant and coordinate the group DoorDash order",
        "usage_hint": "[spin | add | remove | list | admin]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "commands",
        "groups:write",
        "im:write",
        "mpim:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
